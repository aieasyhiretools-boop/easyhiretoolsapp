{
  "name": "EasyHire Tools",
  "slug": "easyhire-tools",
  "version": "1.0.0",
  "assetBundlePatterns": ["**/*"],
  "ios": {
    "supportsTabletMode": true
  },
  "android": {
    "adaptiveIcon": {
      "foregroundImage": "./assets/adaptive-icon.png",
      "backgroundColor": "#007AFF"
    }
  },
  "web": {
    "bundler": "metro",
    "output": "static"
  },
  "plugins": [
    [
      "expo-image-picker",
      {
        "photosPermission": "Allow EasyHire Tools to access your photos.",
        "cameraPermission": "Allow EasyHire Tools to access your camera."
      }
    ]
  ]
}
