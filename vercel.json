{
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "web/build" }
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "web/build/$1"
    },
    {
      "src": "/",
      "dest": "web/build/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
